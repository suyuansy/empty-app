<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:name=".BlankActivity"
            android:excludeFromRecents="true"
            android:exported="true"
            android:theme="@style/SlotTheme" />

        <activity
            android:name=".HostActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity-alias
            android:name=".Lorem"
            android:exported="true"
            android:icon="@mipmap/ic_lorem"
            android:label="@string/app_lorem"
            android:targetActivity=".BlankActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".Ipsum"
            android:exported="true"
            android:icon="@mipmap/ic_ipsum"
            android:label="@string/app_ipsum"
            android:targetActivity=".BlankActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".Amet"
            android:exported="true"
            android:icon="@mipmap/ic_amet"
            android:label="@string/app_amet"
            android:targetActivity=".BlankActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".Vita"
            android:exported="true"
            android:icon="@mipmap/ic_vita"
            android:label="@string/app_vita"
            android:targetActivity=".BlankActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
    </application>
</manifest>
